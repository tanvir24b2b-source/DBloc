PORT=5000

# Set to true for zero-setup in-memory DB (data resets on restart).
# Set to false and fill MONGO_URI for persistent MongoDB Atlas connection.
USE_MEMORY_DB=true
MONGO_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/dbname?tls=true&authSource=admin&retryWrites=true&w=majority

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Seed admin passwords (set strong values before production — falls back to weak defaults if empty)
SEED_MASTER_PASSWORD=
SEED_ADMIN_PASSWORD=

# Your frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary (optional — for product image uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# SSLCommerz (optional — payment gateway)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_LIVE=false

# bKash (optional — payment gateway)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
